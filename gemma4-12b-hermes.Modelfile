# gemma4:12b tuned for the Hermes agent (Nous Research) running locally.
# Hermes requires >= 64000 tokens of context for agentic / tool-use work;
# Ollama's default context is far too small and the agent breaks after a few
# tool calls. gemma4:12b supports up to 262144 natively.
#
# 65536 (64K) is the Hermes floor for agentic / tool-use work — the smallest
# context that survives multi-step tool calls without truncating. Lighter on
# KV cache than 128K, leaving more headroom on 24GB unified memory; bump back
# up if long sessions start losing early context.
#
# Build:   ollama create gemma4-12b-hermes -f gemma4-12b-hermes.Modelfile
# Use:     point the Hermes config at the model name `gemma4-12b-hermes`

FROM gemma4:12b

PARAMETER num_ctx 65536
